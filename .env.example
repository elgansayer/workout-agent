# Copy this file to .env and fill in your real values. Never commit .env.

# Required
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: without a Hevy key the agent still sends a plan, it just cannot
# reference your last logged session.
HEVY_API_KEY=

# With a Hevy key, the agent keeps your training sessions as ready-to-start
# routines in a "Workout Agent" folder in Hevy. Set to 0 to disable.
HEVY_SYNC_ROUTINES=1
# Pre-fill each routine's target weights from your Hevy history (double
# progression: bumps the weight once you hit the top of the rep range). Set 0
# to leave weights blank so Hevy shows your previous working weight instead.
HEVY_PREFILL_WEIGHTS=1

# Every 4-6 weeks the agent runs a routine check-in: it reads your logged Hevy
# history, compares planned vs actual progress per lift, auto-applies the
# findings and sends you a Telegram digest. Set to 0 to disable check-ins.
CHECKIN_ENABLED=1

# Append a daily "what to do today" lifestyle plan (today's session, carb
# cycling, cardio and steps, CNS recovery) to each message, and log it. Set to
# 0 to disable.
LIFESTYLE_ENABLED=1

# Weekly self-review: once a week the agent analyses your Hevy and Google Health
# trends (which lifts are progressing, stalling or regressing, plus recovery)
# and sends a short Telegram digest. Set 0 to disable. SELF_REVIEW_WEEKDAY is the
# day it sends (Mon-Sun, or 0-6 with Monday=0); defaults to Sunday.
SELF_REVIEW_ENABLED=1
SELF_REVIEW_WEEKDAY=Sun

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
# Absolute path to the JSON file exported from Google Health Connect (optional).
# Include body_fat_pct and muscle_pct (e.g. from a Eufy Life scale synced via
# Health Connect) and the agent will log your body composition too.
HEALTH_CONNECT_FILE=

# Automatic body-composition sync (optional, no manual export). A Eufy Life scale
# syncs weight and body fat to Fitbit / Google Health; the agent then reads them
# from the Google Health Web API each run. Create an OAuth client at
# https://developers.google.com/health/setup, then either link it from the web
# dashboard's Settings page (click "Connect Google Health" — no token needed), or
# run `python google_health_auth.py` once to obtain a refresh token to paste here.
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REFRESH_TOKEN=
# Only needed to link Google Health from the web dashboard: the public callback
# URL of the dashboard, also added as an Authorized redirect URI on the OAuth
# client, e.g. https://gym.example.com/google-health/callback
GOOGLE_HEALTH_REDIRECT_URI=
# Path to the SQLite database file (optional)
DATABASE_PATH=workout_agent.db
# Telegram parse mode for formatting. Leave blank for plain text, or set to
# MarkdownV2 to enable formatting (plain text is escaped automatically).
TELEGRAM_PARSE_MODE=
